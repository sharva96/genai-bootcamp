# Copy this file to .env and fill in your values
# Never commit .env to git

OPENAI_API_KEY=sk-proj-your-key-here
CHAT_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small

# ── Guardrails & governance (all optional — sensible defaults shown) ──
MODERATION_MODEL=omni-moderation-latest
ENABLE_MODERATION=true        # set false to skip the Moderation API (heuristics still run)
MOD_THRESHOLD=0.5             # block when any moderation category score ≥ this
MAX_INPUT_CHARS=4000          # hard cap on a single user message
